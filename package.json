{
  "name": "stradl",
  "version": "1.2.5",
  "private": true,
  "description": "Local task management app with priorities, blockers, backups, and a browser-based runtime",
  "author": "Soheyl Vakili",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite\"",
    "build:web": "vite build",
    "build:web:runtime": "vite build --mode runtime",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:web && npm run build:server",
    "build:runtime": "npm run build:web:runtime && npm run build:server",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "verify": "npm run build && npm test",
    "start": "node server/dist/index.js",
    "package:runtime": "npm run build:runtime && node scripts/package-runtime.js && node scripts/generate-checksums.js release",
    "preview": "vite preview",
    "install-service": "node scripts/install-service.js",
    "uninstall-service": "node scripts/uninstall-service.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "test": "vitest run --config vitest.config.server.ts",
    "test:watch": "vitest --config vitest.config.server.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.stradl.desktop",
    "productName": "Stradl",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Stradl-mac-${arch}-v${version}.${ext}"
    }
  }
}
